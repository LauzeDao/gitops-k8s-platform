{
  "uid": "platform-overview",
  "title": "Platform Overview",
  "tags": ["gitops-k8s-platform", "platform"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kube_pod_info, namespace)",
        "definition": "label_values(kube_pod_info, namespace)",
        "refresh": 2,
        "includeAll": false,
        "current": { "text": "tools", "value": "tools" },
        "sort": 1
      },
      {
        "name": "app",
        "label": "App",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kube_pod_labels{namespace=\"$namespace\"}, label_app_kubernetes_io_name)",
        "definition": "label_values(kube_pod_labels{namespace=\"$namespace\"}, label_app_kubernetes_io_name)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "App Health (4 apps + podinfo)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Pods Ready",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_status_ready{namespace=\"$namespace\", condition=\"true\"})" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pods Not Ready",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_status_ready{namespace=\"$namespace\", condition=\"false\"})" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Container Restarts (increase 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 1 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=\"$namespace\"}[1h]))", "legendFormat": "{{pod}}" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "PVC Requested Bytes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 7 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (persistentvolumeclaim) (kube_persistentvolumeclaim_resource_requests_storage_bytes{namespace=\"$namespace\"})", "legendFormat": "{{persistentvolumeclaim}}" }
      ]
    },
    {
      "id": 200,
      "type": "row",
      "title": "Ingress Traffic (per host)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests/s per Host",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (host) (rate(nginx_ingress_controller_requests[5m]))", "legendFormat": "{{host}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "4xx / 5xx Rate per Host",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (host) (rate(nginx_ingress_controller_requests{status=~\"4..\"}[5m]))", "legendFormat": "4xx {{host}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (host) (rate(nginx_ingress_controller_requests{status=~\"5..\"}[5m]))", "legendFormat": "5xx {{host}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "p95 Request Latency per Host",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le, host) (rate(nginx_ingress_controller_request_duration_seconds_bucket[5m])))", "legendFormat": "{{host}}" }
      ]
    },
    {
      "id": 300,
      "type": "row",
      "title": "TLS Certificates",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Certificate Days to Expiry",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "d", "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 14 }, { "color": "green", "value": 30 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(certmanager_certificate_expiration_timestamp_seconds - time()) / 86400", "legendFormat": "{{namespace}}/{{name}}" }
      ]
    },
    {
      "id": 400,
      "type": "row",
      "title": "Loki Logs",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Log Rate per App (lines/s)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 33 },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "sum by (app) (rate({namespace=\"$namespace\", app=~\"$app\"}[5m]))", "legendFormat": "{{app}}" }
      ]
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Logs: $namespace / $app",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 41 },
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "datasource": { "type": "loki", "uid": "loki" }, "expr": "{namespace=\"$namespace\", app=~\"$app\"}" }
      ]
    },
    {
      "id": 500,
      "type": "row",
      "title": "Flux / GitOps Status",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Flux Reconciliations/s (by kind)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 54 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (kind) (rate(gotk_reconcile_duration_seconds_count[5m]))", "legendFormat": "{{kind}}" }
      ]
    }
  ]
}
